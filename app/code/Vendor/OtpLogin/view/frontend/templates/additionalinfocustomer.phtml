    <div class="field zip_code required">
        <label for="zip_code" class="label"><span><?php /* @escapeNotVerified */ echo __('Pin Code'); ?></span></label>
        <div class="control">
            <input type="text" name="zip_code" title="<?php /* @escapeNotVerified */ echo __('Pin Code'); ?>"
            class="input-text only_numeric"
            minlength="6" maxlength="6"
            value="<?php echo $block->getCustomer()->getCustomAttribute('zip_code')->getValue();?>"
