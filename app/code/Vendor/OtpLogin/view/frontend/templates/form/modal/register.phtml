            var regex = new RegExp("^[0-9-]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            var keycode1 = (e.keyCode ? e.keyCode : e.which);
            if (regex.test(str) || (keycode1 == 0 || keycode1 == 9 || keycode1 == 8 || keycode1 == 116)) {
                return true;
            }
            e.preventDefault();
            return false;
