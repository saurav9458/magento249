        function verify(){
            var form_data = $("#form-validate-register").serializeArray();
            $.ajax({                
               // url: "<?php //echo $this->getUrl("otplogin/frontend/otpverify"); ?>",
                url: "<?php echo $this->getUrl("otplogin/frontend/register"); ?>",                
                // data: {'otpvalue': $('#otpvalue').val(),
                //         'mobilenumber':$('input[name="mobile"]').val(),
                //         'isdcode':$('input[name="isd_code"]').val()},
                data:form_data,
                type: 'post',
                dataType: 'json',
                showLoader: true,
                success: function (res) {
                    $('#mobile_verify').val(res.response);
                    $('#otp-message').css("display", "block");
                    if (res.response) {
                        $("#otpvalue").css({'border-color': '#8dc041'});
                        $('#otp-message').html('<div class="message-success success message"><div>'+$.mage.__('Your OTP is successfully verified.')+'</div></div>');
                        $('#verified_mobile').val(res.contactnumber);
                        if(res.islogin){
                            localStorage.setItem("loginMemberShip", "true");
                            window.location.reload(true);
                        }else{
                            $("#register-modal").modal('closeModal');
                        }
                        $('body').trigger('processStop');
                        console.log('eventLogsregister');
                    } else {
                        $('#otp-message').show();
                        $("#otpvalue").css({'border-color': '#ed8380'});
                        $('#otp-message').html('<div class="message-error error message"><div>'+$.mage.__('Your OTP is incorrect or expired, Please enter correct OTP or Resend again.')+'</div></div>');
                        $('#verified_mobile').val('');
                    }
                }
            });
        }
