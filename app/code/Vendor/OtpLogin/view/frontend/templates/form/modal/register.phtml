            $("#otp-message_login").css("display", "none");
            $.ajax({
                url: "<?php echo $this->getUrl("otplogin/frontend/otpverifylogin"); ?>",
                data: {'otpvalue': $('#otpvalue_login').val(),
                        'mobilenumber':$('input[name="mobile_login"]').val(),
                        'isdcode':$('input[name="isd_code_login"]').val()},
                type: 'post',
                dataType: 'json',
                showLoader: true,
                success: function (res) {
                    $('#mobile_verify_login').val(res.response);
                    $('#otp-message_login').css("display", "block");
                    if (res.response) {
                        $("#otpvalue_login").css({'border-color': '#8dc041'});
                        $('#otp-message_login').html('<div class="message-success success message"><div>'+$.mage.__('Your OTP is successfully verified.')+'</div></div>');
                        $('#verified_mobile_login').val(res.contactnumber);
                        window.location.reload(true);
                    } else {
                        $('#otp-message_login').show();
                        $("#otpvalue_login").css({'border-color': '#ed8380'});
                        $('#otp-message_login').html('<div class="message-error error message"><div>'+$.mage.__('Your OTP is incorrect or expired, Please enter correct OTP or Resend again.')+'</div></div>');
                        $('#verified_mobile_login').val('');
                    }
                }
            });
        }
    function sendlogin(){
            if (window.matchMedia('(max-width: 767px)').matches) {
                $('#mobile').css("width", "87%");
            }
            $('#loader_login').css("display", "inline-block");
            $("#otp-message_login").css("display", "none");
            $("#otpvalue_login").val('');
            $("#otpvalue_login").css({'border-color': '#d1d1d1'});
            $.ajax({
            //    showLoader: true,
                url: "<?php echo $this->getUrl("otplogin/frontend/otpsend"); ?>",
                data:  {'mobilenumber':$('input[name="mobile_login"]').val(),
                        'isdcode':$('input[name="isd_code_login"]').val(),
                        'login':true},
                type: "POST",
                dataType: 'json'
            }).done(function (res) {
                $('#loader_login').css("display", "none");
                if (window.matchMedia('(max-width: 767px)').matches) {
                    $('#mobile_login').css("width", "100%");
                }
                $('#mobile-message_login').css("display", "block");
                $('#mobile-message_login').html('<span>&nbsp;</span>'+res.messages);
                $('#mobile-verify-btn_login').css("display", "none");
                $('#resend_login').css("display", "block");
                $('#resend_login').css("margin-left", "5px");
                setTimeout(function() {
                    $("#mobile-message").hide('blind', {}, 1000);
                }, 10000);
            });
        }
    $( "#resend_login" ).click(function() {
    	   $('input[name="mobile_login"]').validation();
  	    if($('input[name="mobile_login"]').validation('isValid')){
                sendlogin();
	    }
	});
});
</script>
