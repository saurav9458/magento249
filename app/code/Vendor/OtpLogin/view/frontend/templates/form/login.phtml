<script>
require([
    'jquery',
    'mage/mage',
], function($){
    
        $('button#otp-verify-btn').css({left: '107px'});
        $('button#resend').css({left: '220px'});
        $("#otpvalue").focusout(function() {
            $("#otpvalue").css({'border-color': '#d1d1d1'});
        });
        $('input[name="mobile"]').keypress(function (e) {
            var regex = new RegExp("^[0-9-]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            var keycode1 = (e.keyCode ? e.keyCode : e.which);
            if (regex.test(str) || (keycode1 == 0 || keycode1 == 9 || keycode1 == 8 || keycode1 == 116)) {
                return true;
            }
            e.preventDefault();
            return false;
        });
        $('button#mobile-verify-btn').on('click', function(){
            $('input[name="mobile"]').validation();
            $('input[name="isd_code"]').validation();
  	    if($('input[name="mobile"]').validation('isValid') && $('input[name="isd_code"]').validation('isValid') ){
                send();
	    }
        });
        $('button#otp-verify-btn').on('click', function(){
            $('input[name="otpvalue"]').validation();
  	    if($('input[name="otpvalue"]').validation('isValid')){
                verify();
	    }
        });
        function verify(){
            $.ajax({
                url: "<?php echo $this->getUrl("otplogin/frontend/otpverify"); ?>",
                data: {'otpvalue': $('#otpvalue').val(),
                        'mobilenumber':$('input[name="mobile"]').val(),
                        'isdcode':$('input[name="isd_code"]').val()},
                type: 'post',
                dataType: 'json',
                // showLoader: true,
                success: function (res) {
                    $('#mobile_verify').val(res.response);
                    $('#otp-message').css("display", "block");
                    if (res.response) {
                        $("#otpvalue").css({'border-color': '#8dc041'});
                        $('#otp-message').html('<div class="message-success success message"><div>'+$.mage.__('Your OTP is successfully verified.')+'</div></div>');
                        $('#verified_mobile').val(res.contactnumber);
                    } else {
                        $("#otpvalue").css({'border-color': '#ed8380'});
                        $('#otp-message').html('<div class="message-error error message"><div>'+$.mage.__('Your OTP is incorrect or expired, Please enter correct OTP or Resend again.')+'</div></div>');
                        $('#verified_mobile').val('');
                    }
                }
            });
        }
        function send(){
            if (window.matchMedia('(max-width: 767px)').matches) {
                $('#mobile').css("width", "87%");
            }
            $('#loader').css("display", "inline-block");
            $("#otp-message").css("display", "none");
            $("#otpvalue").val('');
            $("#otpvalue").css({'border-color': '#d1d1d1'});
            $.ajax({
            //    showLoader: true,
                url: "<?php echo $this->getUrl("otplogin/frontend/otpsend"); ?>",
                data:  {'mobilenumber':$('input[name="mobile"]').val(),
                        'isdcode':$('input[name="isd_code"]').val(),
                        'login':true},
                type: "POST",
                dataType: 'json'
            }).done(function (res) {
                $('#loader').css("display", "none");
                if (window.matchMedia('(max-width: 767px)').matches) {
                    $('#mobile').css("width", "100%");
                }
                $('#mobile-message').css("display", "block");
                $('#mobile-message').html('<span>&nbsp;</span>'+res.messages);
                setTimeout(function() {
                    $("#mobile-message").hide('blind', {}, 1000);
                }, 10000);
            });
        }
	$( "#resend" ).click(function() {
    	   $('input[name="mobile"]').validation();
  	    if($('input[name="mobile"]').validation('isValid')){
                send();
	    }
	});
	$('#login-form').submit(function() {
            if($('#login-form').validation('isValid')){
                if($('#verified_mobile').val() != $('#mobile').val() || !$('#mobile_verify').val() || !$('#verified_mobile').val()){
                    $('#otp-message').css("display", "block");
                    $('#otp-message').html('<div class="message-error error message"><div><?php echo __('Mobile number is not verified'); ?></div></div>');
                    setTimeout(function() {
                        $("#otp-message").hide('blind', {}, 1000);
                    }, 5000);
                    return false;
                }
            }
	});

});
</script>