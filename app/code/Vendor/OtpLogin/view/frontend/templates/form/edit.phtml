<script>
require([
    'jquery',
    'mage/mage',
], function($){
    
        $('button#otp-verify-btn-edit').css({left: '107px'});
        $('button#resend-edit').css({left: '220px'});
        $("#otpvalue-edit").focusout(function() {
            $("#otpvalue-edit").css({'border-color': '#d1d1d1'});
        });
        $('input[name="mobile-edit"]').keypress(function (e) {
            var regex = new RegExp("^[0-9-]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            var keycode1 = (e.keyCode ? e.keyCode : e.which);
            if (regex.test(str) || (keycode1 == 0 || keycode1 == 9 || keycode1 == 8 || keycode1 == 116)) {
                return true;
            }
            e.preventDefault();
            return false;
        });
        $('button#mobile-verify-btn-edit').on('click', function(){
            $('input[name="mobile-edit"]').validation();
            $('input[name="isd_code-edit"]').validation();
  	    if($('input[name="mobile-edit"]').validation('isValid') && $('input[name="isd_code-edit"]').validation('isValid') ){
                send();
	    }
        });
        $('button#otp-verify-btn-edit').on('click', function(){
            $('input[name="otpvalue-edit"]').validation();
  	    if($('input[name="otpvalue-edit"]').validation('isValid')){
                verify();
	    }
        });
        function verify(){
            $.ajax({
                url: "<?php echo $this->getUrl("otplogin/frontend/otpverify"); ?>",
                data: {'otpvalue': $('#otpvalue-edit').val(),
                        'mobilenumber':$('input[name="mobile-edit"]').val(),
                        'isdcode':$('input[name="isd_code-edit"]').val()},
                type: 'post',
                dataType: 'json',
                // showLoader: true,
                success: function (res) {
                    $('#mobile_verify-edit').val(res.response);
                    $('#otp-message-edit').css("display", "block");
                    if (res.response) {
                        $("#otpvalue-edit").css({'border-color': '#8dc041'});
                        $('#otp-message-edit').html('<div class="message-success success message"><div>'+$.mage.__('Your OTP is successfully verified.')+'</div></div>');
                        $('#verified_mobile-edit').val(res.contactnumber);
                    } else {
                        $("#otpvalue-edit").css({'border-color': '#ed8380'});
                        $('#otp-message-edit').html('<div class="message-error error message"><div>'+$.mage.__('Your OTP is incorrect or expired, Please enter correct OTP or Resend again.')+'</div></div>');
                        $('#verified_mobile-edit').val('');
                    }
                }
            });
        }
        function send(){
            if (window.matchMedia('(max-width: 767px)').matches) {
                $('#mobile-edit').css("width", "87%");
            }
            $('#loader-edit').css("display", "inline-block");
            $("#otp-message-edit").css("display", "none");
            $("#otpvalue-edit").val('');
            $("#otpvalue-edit").css({'border-color': '#d1d1d1'});
            $.ajax({
            //    showLoader: true,
                url: "<?php echo $this->getUrl("otplogin/frontend/otpsend"); ?>",
                data:  {'mobilenumber':$('input[name="mobile-edit"]').val(),
                        'isdcode':$('input[name="isd_code-edit"]').val(),
                        'login':true},
                type: "POST",
                dataType: 'json'
            }).done(function (res) {
                $('#loader-edit').css("display", "none");
                if (window.matchMedia('(max-width: 767px)').matches) {
                    $('#mobile-edit').css("width", "100%");
                }
                $('#mobile-message-edit').css("display", "block");
                $('#mobile-message-edit').html('<span>&nbsp;</span>'+res.messages);
                setTimeout(function() {
                    $("#mobile-message-edit").hide('blind', {}, 1000);
                }, 10000);
            });
        }
	$( "#resend-edit" ).click(function() {
    	   $('input[name="mobile-edit"]').validation();
  	    if($('input[name="mobile-edit"]').validation('isValid')){
                send();
	    }
	});
	$('#login-form-edit').submit(function() {
            if($('#login-form-edit').validation('isValid')){
                if($('#verified_mobile-edit').val() != $('#mobile-edit').val() || !$('#mobile_verify-edit').val() || !$('#verified_mobile-edit').val()){
                    $('#otp-message-edit').css("display", "block");
                    $('#otp-message-edit').html('<div class="message-error error message"><div><?php echo __('Mobile number is not verified'); ?></div></div>');
                    setTimeout(function() {
                        $("#otp-message-edit").hide('blind', {}, 1000);
                    }, 5000);
                    return false;
                }
            }
	});

});
</script>
